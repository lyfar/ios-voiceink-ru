fastlane_version "2.233.0"
default_platform(:ios)
require "json"

# Run all paths relative to the repo root, not fastlane/
PROJECT_ROOT = File.expand_path("..", __dir__)
Dir.chdir(PROJECT_ROOT)

APP_IDENTIFIER       = "lol.egor.voiceink-ru"
KEYBOARD_IDENTIFIER  = "lol.egor.voiceink-ru.keyboard"
TESTS_IDENTIFIER     = "lol.egor.voiceink-ru.tests"
UITESTS_IDENTIFIER   = "lol.egor.voiceink-ru.uitests"
APP_GROUP_IDENTIFIER = "group.lol.egor.voiceink-ru"
APP_NAME             = "VoiceInk RU"
TEAM_ID              = "5C5L6DFJGS"
PROJECT              = "VoiceInk-ios.xcodeproj"
SCHEME               = "VoiceInk-ios"
SHERPA_VERSION       = "v1.13.1"

API_KEY_PATH = File.expand_path(ENV["APP_STORE_CONNECT_API_KEY_PATH"] || "~/secrets/appstore/api_key.json")

def api_token
  key = JSON.parse(File.read(API_KEY_PATH))
  Spaceship::ConnectAPI::Token.create(
    key_id: key.fetch("key_id"),
    issuer_id: key.fetch("issuer_id"),
    filepath: File.expand_path(ENV["APP_STORE_CONNECT_API_KEY_FILE"] || "~/secrets/appstore/AuthKey_#{key.fetch('key_id')}.p8"),
    duration: key.fetch("duration", 500),
  )
end

def fastlane_api_key
  key = JSON.parse(File.read(API_KEY_PATH))
  app_store_connect_api_key(
    key_id: key.fetch("key_id"),
    issuer_id: key.fetch("issuer_id"),
    key_filepath: File.expand_path(ENV["APP_STORE_CONNECT_API_KEY_FILE"] || "~/secrets/appstore/AuthKey_#{key.fetch('key_id')}.p8"),
    duration: key.fetch("duration", 500),
    in_house: false,
  )
end

# Sherpa-onnx ships TWO XCFrameworks (sherpa-onnx + onnxruntime), both needed
# at runtime. The bridging header isn't in the tarball — pulled from GitHub
# master. All idempotent.
def ensure_sherpa_onnx
  fw_sherpa  = File.join(PROJECT_ROOT, "Frameworks/sherpa-onnx.xcframework")
  fw_onnxrt  = File.join(PROJECT_ROOT, "Frameworks/onnxruntime.xcframework")
  bridging   = File.join(PROJECT_ROOT, "VoiceInk-ios/SherpaOnnx-Bridging-Header.h")
  if File.directory?(fw_sherpa) && File.directory?(fw_onnxrt) && File.exist?(bridging)
    UI.message "sherpa-onnx already present, skipping download"
    return
  end
  UI.message "Downloading sherpa-onnx #{SHERPA_VERSION}..."
  sh "mkdir -p '#{PROJECT_ROOT}/Frameworks' /tmp/sherpa-dl"
  url = "https://github.com/k2-fsa/sherpa-onnx/releases/download/#{SHERPA_VERSION}/sherpa-onnx-#{SHERPA_VERSION}-ios-no-tts.tar.bz2"
  unless File.exist?("/tmp/sherpa-dl/sherpa.tar.bz2")
    sh "curl -sSL -o /tmp/sherpa-dl/sherpa.tar.bz2 '#{url}'"
  end
  sh "tar -xjf /tmp/sherpa-dl/sherpa.tar.bz2 -C /tmp/sherpa-dl"
  src_root = "/tmp/sherpa-dl/build-ios-no-tts"
  sh "rm -rf '#{fw_sherpa}' '#{fw_onnxrt}'"
  sh "cp -R '#{src_root}/sherpa-onnx.xcframework' '#{PROJECT_ROOT}/Frameworks/'"
  onnxrt = Dir.glob("#{src_root}/ios-onnxruntime/*/onnxruntime.xcframework").first
  UI.user_error!("could not find onnxruntime.xcframework in tarball") unless onnxrt
  sh "cp -R '#{onnxrt}' '#{PROJECT_ROOT}/Frameworks/'"
  File.write(bridging, <<~HEADER)
    // SherpaOnnx-Bridging-Header.h
    // Bridges sherpa-onnx C-API into Swift. Generated by VoiceInk RU build.
    #ifndef SHERPAONNX_BRIDGING_HEADER_H
    #define SHERPAONNX_BRIDGING_HEADER_H
    #import "sherpa-onnx/c-api/c-api.h"
    #endif
  HEADER
  UI.success "sherpa-onnx ready"
end

# Wire sherpa-onnx.xcframework into the Xcode project: add as a file reference,
# embed&sign on the main + keyboard targets, set the bridging header build
# setting. Idempotent — checks if a reference already exists before adding.
def integrate_sherpa_onnx
  require "xcodeproj"
  proj_path = File.join(PROJECT_ROOT, "VoiceInk-ios.xcodeproj")
  proj = Xcodeproj::Project.open(proj_path)

  # Both frameworks live in Frameworks/ — main app target embeds them.
  # The keyboard extension does NOT — it has a 50-70 MB memory cap on iOS;
  # transcription happens in the main app via App Group + Darwin notifications
  # (existing pattern in the original VoiceInk-iOS).
  frameworks = ["sherpa-onnx.xcframework", "onnxruntime.xcframework"]
  frameworks_group = proj.main_group["Frameworks"] || proj.main_group.new_group("Frameworks", "Frameworks")

  refs = frameworks.map do |fw|
    ref = frameworks_group.files.find { |f| f.path&.end_with?(fw) }
    unless ref
      ref = frameworks_group.new_file(fw)
      ref.set_source_tree("SOURCE_ROOT")
      ref.set_path("Frameworks/#{fw}")
      UI.success "Added #{fw} to project"
    end
    ref
  end

  main_target = proj.targets.find { |t| t.name == "VoiceInk-ios" }
  UI.user_error!("VoiceInk-ios target not found") unless main_target

  # Link + embed both frameworks in the main app target only.
  link_phase = main_target.frameworks_build_phase
  embed_phase = main_target.copy_files_build_phases.find { |p| p.dst_subfolder_spec == "10" }
  embed_phase ||= main_target.new_copy_files_build_phase("Embed Frameworks").tap do |p|
    p.symbol_dst_subfolder_spec = :frameworks
  end

  refs.each do |ref|
    unless link_phase.files_references.include?(ref)
      link_phase.add_file_reference(ref)
      UI.success "Linked #{ref.path} into VoiceInk-ios"
    end
    unless embed_phase.files_references.include?(ref)
      bf = embed_phase.add_file_reference(ref)
      bf.settings = { "ATTRIBUTES" => ["CodeSignOnCopy", "RemoveHeadersOnCopy"] }
      UI.success "Embed&Sign #{ref.path} in VoiceInk-ios"
    end
  end

  main_target.build_configurations.each do |cfg|
    cfg.build_settings["SWIFT_OBJC_BRIDGING_HEADER"] = "VoiceInk-ios/SherpaOnnx-Bridging-Header.h"
    paths = cfg.build_settings["FRAMEWORK_SEARCH_PATHS"] || ["$(inherited)"]
    paths = [paths] unless paths.is_a?(Array)
    paths << "$(SRCROOT)/Frameworks"
    cfg.build_settings["FRAMEWORK_SEARCH_PATHS"] = paths.uniq
  end

  # Add new GigaAM Swift files to the main target's compile sources phase.
  swift_files = [
    "VoiceInk-ios/GigaAMTranscriptionService.swift",
    "VoiceInk-ios/GigaAMModelManager.swift",
    "VoiceInk-ios/GigaAMSetupView.swift",
  ]
  main_target = proj.targets.find { |t| t.name == "VoiceInk-ios" }
  main_group  = proj.main_group["VoiceInk-ios"] || proj.main_group
  swift_files.each do |relpath|
    next unless File.exist?(relpath)
    sources_phase = main_target.source_build_phase
    already = sources_phase.files_references.any? { |f| f.real_path.to_s.end_with?(File.basename(relpath)) }
    next if already
    file_ref = main_group.new_file(File.basename(relpath))
    file_ref.set_source_tree("SOURCE_ROOT")
    file_ref.set_path(relpath)
    sources_phase.add_file_reference(file_ref)
    UI.success "Added #{relpath} to compile sources"
  end

  proj.save
  UI.success "Project file written"
end

platform :ios do
  desc "End-to-end: register IDs, profiles, build IPA, push to R2, publish."
  lane :ship do
    ensure_sherpa_onnx
    integrate_sherpa_onnx
    register_or_skip
    sync_profiles
    build_adhoc
    push_to_r2
  end

  desc "Create Bundle IDs in Apple Dev portal if missing."
  lane :register_or_skip do
    Spaceship::ConnectAPI.token = api_token
    [
      [APP_IDENTIFIER,      APP_NAME],
      [KEYBOARD_IDENTIFIER, "#{APP_NAME} Keyboard"],
      [TESTS_IDENTIFIER,    "#{APP_NAME} Tests"],
      [UITESTS_IDENTIFIER,  "#{APP_NAME} UITests"],
    ].each do |ident, name|
      bundle = Spaceship::ConnectAPI::BundleId.find(ident)
      if bundle
        UI.message "Bundle exists: #{ident}"
      else
        Spaceship::ConnectAPI::BundleId.create(name: name, platform: "IOS", identifier: ident)
        UI.success "Created Bundle ID: #{ident}"
      end
    end
  end

  desc "Sync ad-hoc provisioning profiles via match-style auto sigh."
  lane :sync_profiles do
    Spaceship::ConnectAPI.token = api_token
    [APP_IDENTIFIER, KEYBOARD_IDENTIFIER].each do |ident|
      sigh(
        api_key: fastlane_api_key,
        adhoc: true,
        app_identifier: ident,
        force: true,                    # rotate to include the iPhone UDID just registered
        provisioning_name: "VoiceInk RU AdHoc #{ident.split('.').last}",
        output_path: "build/signing",
        skip_install: true,             # we'll install via xcodebuild's allowProvisioningUpdates
      )
    end
  end

  desc "Build signed ad-hoc IPA"
  lane :build_adhoc do
    bump = ENV["BUILD_NUMBER"] || Time.now.strftime("%Y%m%d%H%M")
    increment_build_number(xcodeproj: PROJECT, build_number: bump)
    sh "rm -rf build/adhoc"
    gym(
      project: PROJECT,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "ad-hoc",
      export_team_id: TEAM_ID,
      output_directory: "build/adhoc",
      output_name: "VoiceInk-RU.ipa",
      clean: true,
      include_bitcode: false,
      include_symbols: false,
      export_options: {
        method: "ad-hoc",
        teamID: TEAM_ID,
        signingStyle: "automatic",
        compileBitcode: false,
        thinning: "<none>",
      },
      xcargs: "-allowProvisioningUpdates",
    )
    UI.success "IPA at build/adhoc/VoiceInk-RU.ipa"
  end

  desc "Upload IPA + manifest to Cloudflare R2 (beta.voice.egor.lol)."
  lane :push_to_r2 do
    require "shellwords"
    bucket = "voice-ink-ru-beta"
    ipa = "build/adhoc/VoiceInk-RU.ipa"
    UI.user_error!("missing #{ipa}") unless File.exist?(ipa)

    build = `/usr/libexec/PlistBuddy -c "Print :CFBundleVersion" VoiceInk-ios/Info.plist`.strip
    marketing = `/usr/libexec/PlistBuddy -c "Print :CFBundleShortVersionString" VoiceInk-ios/Info.plist 2>/dev/null`.strip
    marketing = "1.0" if marketing.empty?
    versioned_name = "VoiceInk-RU-#{build}.ipa"

    # Source the CF token from secrets file.
    cf_env = "CLOUDFLARE_API_TOKEN=$(grep '^CLOUDFLARE_API_TOKEN=' ~/secrets/cloudflare/sound-healing.env | cut -d= -f2-) " \
             "CLOUDFLARE_ACCOUNT_ID=$(grep '^CLOUDFLARE_ACCOUNT_ID=' ~/secrets/cloudflare/sound-healing.env | cut -d= -f2-)"
    wrangler = "npx --yes wrangler@latest"

    sh "#{cf_env} #{wrangler} r2 object put #{bucket}/ipa/#{versioned_name} --file #{ipa} --content-type 'application/octet-stream' --cache-control 'public, max-age=31536000, immutable' --remote"
    sh "#{cf_env} #{wrangler} r2 object put #{bucket}/ipa/VoiceInk-RU-latest.ipa --file #{ipa} --content-type 'application/octet-stream' --cache-control 'public, max-age=300' --remote"

    manifest = <<~PLIST
      <?xml version="1.0" encoding="UTF-8"?>
      <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
      <plist version="1.0">
      <dict>
        <key>items</key>
        <array>
          <dict>
            <key>assets</key>
            <array>
              <dict>
                <key>kind</key><string>software-package</string>
                <key>url</key><string>https://beta.voice.egor.lol/ipa/VoiceInk-RU-latest.ipa</string>
              </dict>
            </array>
            <key>metadata</key>
            <dict>
              <key>bundle-identifier</key><string>#{APP_IDENTIFIER}</string>
              <key>bundle-version</key><string>#{build}</string>
              <key>kind</key><string>software</string>
              <key>title</key><string>#{APP_NAME}</string>
            </dict>
          </dict>
        </array>
      </dict>
      </plist>
    PLIST
    File.write("/tmp/manifest.plist", manifest)
    sh "#{cf_env} #{wrangler} r2 object put #{bucket}/manifest.plist --file /tmp/manifest.plist --content-type 'application/xml' --cache-control 'public, max-age=300' --remote"

    template = File.read("site/index.html.template")
    rendered = template
      .gsub("__BUILD__", build)
      .gsub("__VERSION__", marketing)
      .gsub("__DATE__", Time.now.utc.strftime("%Y-%m-%dT%H:%M:%SZ"))
    File.write("/tmp/index.html", rendered)
    sh "#{cf_env} #{wrangler} r2 object put #{bucket}/index.html --file /tmp/index.html --content-type 'text/html; charset=utf-8' --cache-control 'public, max-age=300' --remote"

    UI.success "Pushed build #{build} to https://beta.voice.egor.lol/"
    UI.success "Direct OTA install: itms-services://?action=download-manifest&url=https://beta.voice.egor.lol/manifest.plist"
  end
end

  lane :wire_sherpa do
    ensure_sherpa_onnx
    integrate_sherpa_onnx
  end

  lane :strip_whisper do
    require "xcodeproj"
    proj = Xcodeproj::Project.open(File.join(PROJECT_ROOT, "VoiceInk-ios.xcodeproj"))
    # 1. Remove whisper.xcframework file refs everywhere
    proj.objects.dup.each do |o|
      next unless o.respond_to?(:path) && o.path.to_s.include?("whisper.xcframework")
      proj.targets.each do |t|
        t.build_phases.each do |ph|
          next unless ph.respond_to?(:files)
          ph.files.delete_if { |bf| bf.file_ref == o }
        end
      end
      o.remove_from_project rescue nil
      UI.success "stripped whisper.xcframework ref"
    end
    # 2. Remove whisper-related Swift files from compile sources
    %w[LibWhisper.swift WhisperTranscriptionService.swift LocalModelManager.swift LocalModelManagementView.swift].each do |fname|
      proj.files.dup.each do |fr|
        next unless fr.path&.end_with?(fname) || fr.name == fname
        proj.targets.each do |t|
          t.build_phases.each do |ph|
            next unless ph.respond_to?(:files)
            ph.files.delete_if { |bf| bf.file_ref == fr }
          end
        end
        fr.remove_from_project rescue nil
        UI.success "stripped #{fname}"
      end
    end
    proj.save
    UI.success "Project file written without whisper deps"
  end

  lane :register_app_group do
    Spaceship::ConnectAPI.token = api_token
    group_id = "group.lol.egor.voiceink-ru"
    group_name = "VoiceInk RU App Group"
    existing = Spaceship::Portal.app_group.find(group_id)
    if existing
      UI.message "App Group already registered: #{group_id}"
    else
      Spaceship::Portal.app_group.create!(group_id: group_id, name: group_name)
      UI.success "Created App Group: #{group_id}"
    end
    # Wire to Bundle IDs
    [APP_IDENTIFIER, KEYBOARD_IDENTIFIER].each do |ident|
      app = Spaceship::Portal.app.find(ident)
      next unless app
      app.associate_groups([Spaceship::Portal.app_group.find(group_id)])
      UI.success "Linked App Group to #{ident}"
    end
  end

  lane :register_app_group_v2 do
    Spaceship::ConnectAPI.token = api_token
    group_id = "group.lol.egor.voiceink-ru"

    # 1. Create or fetch App Group via ConnectAPI.
    require "spaceship/connect_api/models/app_group"
    existing_groups = Spaceship::ConnectAPI.client.get_app_groups(filter: { identifier: group_id }).all_pages
    group = existing_groups.flatten.find { |g| g.respond_to?(:identifier) && g.identifier == group_id } rescue nil
    if group.nil?
      begin
        group = Spaceship::ConnectAPI.post_app_group(name: "VoiceInk RU App Group", identifier: group_id)
        UI.success "Created App Group: #{group_id}"
      rescue => e
        UI.important "post_app_group not available — falling back to capability enable: #{e.message}"
      end
    else
      UI.message "App Group exists: #{group_id}"
    end

    # 2. Enable APP_GROUPS capability on each app's Bundle ID and link the group.
    [APP_IDENTIFIER, KEYBOARD_IDENTIFIER].each do |ident|
      bundle = Spaceship::ConnectAPI::BundleId.find(ident)
      next unless bundle
      caps = bundle.bundle_id_capabilities
      already = caps.any? { |c| c.capability_type == "APP_GROUPS" }
      unless already
        Spaceship::ConnectAPI::BundleIdCapability.create(bundle_id: bundle, capability_type: "APP_GROUPS")
        UI.success "Enabled APP_GROUPS on #{ident}"
      else
        UI.message "APP_GROUPS already on #{ident}"
      end
    end
  end

  lane :probe_capabilities do
    Spaceship::ConnectAPI.token = api_token
    bundle = Spaceship::ConnectAPI::BundleId.find(APP_IDENTIFIER)
    UI.message "bundle: #{bundle.inspect[0..200]}"
    client = Spaceship::ConnectAPI.client
    UI.message "client respond_to: #{client.methods.grep(/app_group|capability|app_id/i)}"
  end

  lane :probe_methods do
    Spaceship::ConnectAPI.token = api_token
    client = Spaceship::ConnectAPI.client
    UI.message "All HTTP methods on client:"
    client.methods.grep(/^(post|get|patch|delete)_/).sort.each { |m| UI.message "  #{m}" }
  end

  lane :register_app_group_raw do
    require "json"; require "net/http"; require "uri"
    Spaceship::ConnectAPI.token = api_token
    jwt = Spaceship::ConnectAPI.token.text  # JWT bearer string

    # 1. Look up App Group
    grp_id = "group.lol.egor.voiceink-ru"
    headers = { "Authorization" => "Bearer #{jwt}", "Content-Type" => "application/json" }
    list_resp = Net::HTTP.start("api.appstoreconnect.apple.com", 443, use_ssl: true) do |http|
      req = Net::HTTP::Get.new("/v1/appGroups?filter[identifier]=#{grp_id}")
      headers.each { |k, v| req[k] = v }
      http.request(req)
    end
    list = JSON.parse(list_resp.body) rescue {}
    UI.message "GET /v1/appGroups → #{list_resp.code}, data=#{list.dig('data')&.length}"

    if (list.dig("data") || []).empty?
      UI.message "Creating App Group #{grp_id}..."
      payload = {
        data: { type: "appGroups",
                attributes: { name: "VoiceInk RU App Group", identifier: grp_id } }
      }
      create_resp = Net::HTTP.start("api.appstoreconnect.apple.com", 443, use_ssl: true) do |http|
        req = Net::HTTP::Post.new("/v1/appGroups")
        headers.each { |k, v| req[k] = v }
        req.body = payload.to_json
        http.request(req)
      end
      UI.message "POST /v1/appGroups → #{create_resp.code} #{create_resp.body[0..400]}"
    else
      UI.success "App Group already exists: #{grp_id}"
    end

    # 2. Enable APP_GROUPS capability + bind group on each bundle id
    [APP_IDENTIFIER, KEYBOARD_IDENTIFIER].each do |ident|
      bundle = Spaceship::ConnectAPI::BundleId.find(ident)
      next unless bundle
      caps = bundle.bundle_id_capabilities
      has_cap = caps.any? { |c| c.capability_type == "APP_GROUPS" }
      unless has_cap
        Spaceship::ConnectAPI.client.post_bundle_id_capability(bundle_id_id: bundle.id, capability_type: "APP_GROUPS")
        UI.success "Enabled APP_GROUPS capability on #{ident}"
      end
    end
  end

  lane :test_appgroup_post do
    require "json"; require "net/http"
    Spaceship::ConnectAPI.token = api_token
    jwt = Spaceship::ConnectAPI.token.text
    headers = { "Authorization" => "Bearer #{jwt}", "Content-Type" => "application/json" }

    UI.message "probe GET /v1/appGroups..."
    r = Net::HTTP.start("api.appstoreconnect.apple.com", 443, use_ssl: true) do |h|
      req = Net::HTTP::Get.new("/v1/appGroups?filter[identifier]=group.lol.egor.voiceink-ru")
      headers.each { |k,v| req[k] = v }
      h.request(req)
    end
    UI.message "  #{r.code}: #{r.body[0..400]}"

    if r.body.include?('"data":[]')
      UI.message "POST /v1/appGroups..."
      payload = { data: { type: "appGroups",
                          attributes: { identifier: "group.lol.egor.voiceink-ru",
                                        name: "VoiceInk RU App Group" } } }
      r = Net::HTTP.start("api.appstoreconnect.apple.com", 443, use_ssl: true) do |h|
        req = Net::HTTP::Post.new("/v1/appGroups")
        headers.each { |k,v| req[k] = v }
        req.body = payload.to_json
        h.request(req)
      end
      UI.message "  #{r.code}: #{r.body[0..600]}"
    end
  end

  lane :enable_app_groups do
    Spaceship::ConnectAPI.token = api_token
    [APP_IDENTIFIER, KEYBOARD_IDENTIFIER].each do |ident|
      bundle = Spaceship::ConnectAPI::BundleId.find(ident)
      next unless bundle
      caps = Array(bundle.bundle_id_capabilities)
      has_cap = caps.any? { |c| c.capability_type == "APP_GROUPS" }
      if has_cap
        UI.message "APP_GROUPS already enabled on #{ident}"
      else
        Spaceship::ConnectAPI.client.post_bundle_id_capability(
          bundle_id_id: bundle.id, capability_type: "APP_GROUPS",
        )
        UI.success "Enabled APP_GROUPS capability on #{ident}"
      end
    end
  end

  lane :probe_appgroup_via_capabilities do
    require "json"; require "net/http"
    Spaceship::ConnectAPI.token = api_token
    jwt = Spaceship::ConnectAPI.token.text
    headers = { "Authorization" => "Bearer #{jwt}", "Content-Type" => "application/json" }

    # Look up bundle id
    bundle = Spaceship::ConnectAPI::BundleId.find(APP_IDENTIFIER)
    UI.message "bundle id internal id: #{bundle.id}"

    # Get its capabilities with includes
    UI.message "GET /v1/bundleIds/#{bundle.id}/capabilities?include=appGroups"
    r = Net::HTTP.start("api.appstoreconnect.apple.com", 443, use_ssl: true) do |h|
      req = Net::HTTP::Get.new("/v1/bundleIds/#{bundle.id}/capabilities?include=appGroups")
      headers.each { |k,v| req[k] = v }
      h.request(req)
    end
    UI.message "  #{r.code}: #{r.body[0..800]}"
    UI.message ""

    # Try GET on the capability resource directly
    UI.message "GET /v1/bundleIdCapabilities (filter by bundle):"
    r = Net::HTTP.start("api.appstoreconnect.apple.com", 443, use_ssl: true) do |h|
      req = Net::HTTP::Get.new("/v1/bundleIdCapabilities?filter[bundleId]=#{bundle.id}&include=appGroups")
      headers.each { |k,v| req[k] = v }
      h.request(req)
    end
    UI.message "  #{r.code}: #{r.body[0..800]}"
  end

  lane :probe_api_key_role do
    require "json"; require "net/http"
    Spaceship::ConnectAPI.token = api_token
    jwt = Spaceship::ConnectAPI.token.text
    headers = { "Authorization" => "Bearer #{jwt}", "Content-Type" => "application/json" }

    UI.message "Token kid (key_id): #{Spaceship::ConnectAPI.token.key_id}"
    UI.message "Token issuer_id: #{Spaceship::ConnectAPI.token.issuer_id}"
    UI.message "Token text decoded payload:"
    body = Spaceship::ConnectAPI.token.text.split('.')[1]
    require "base64"
    payload = JSON.parse(Base64.decode64(body + "==="))
    UI.message payload.inspect
  end

  lane :fix_header_paths do
    require "xcodeproj"
    proj = Xcodeproj::Project.open(File.join(PROJECT_ROOT, "VoiceInk-ios.xcodeproj"))
    main_target = proj.targets.find { |t| t.name == "VoiceInk-ios" }
    main_target.build_configurations.each do |cfg|
      paths = Array(cfg.build_settings["HEADER_SEARCH_PATHS"] || ["$(inherited)"])
      paths += [
        "$(SRCROOT)/Frameworks/sherpa-onnx.xcframework/Headers",
        "$(SRCROOT)/Frameworks/onnxruntime.xcframework/Headers",
      ]
      cfg.build_settings["HEADER_SEARCH_PATHS"] = paths.uniq
      UI.message "set HEADER_SEARCH_PATHS for #{cfg.name}: #{paths}"
    end
    proj.save
    UI.success "Updated header search paths"
  end
